{
  "name": "hscli",
  "version": "0.5.0",
  "description": "Command-line interface for Help Scout",
  "type": "module",
  "license": "MIT",
  "author": "Eric Rodriguez",
  "homepage": "https://github.com/wavyx/hscli",
  "repository": {
    "type": "git",
    "url": "https://github.com/wavyx/hscli.git"
  },
  "bugs": {
    "url": "https://github.com/wavyx/hscli/issues"
  },
  "bin": {
    "hs": "./bin/run.js"
  },
  "files": [
    "bin",
    "src",
    "oclif.manifest.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "helpscout",
    "help-scout",
    "cli",
    "oclif",
    "support",
    "customer-support",
    "inbox"
  ],
  "oclif": {
    "bin": "hs",
    "dirname": "hscli",
    "commands": {
      "strategy": "pattern",
      "target": "./src/commands",
      "globPatterns": [
        "**/*.js",
        "!**/*.test.js"
      ]
    },
    "topicSeparator": " ",
    "topics": {
      "auth": {
        "description": "Authentication and OAuth management"
      },
      "conv": {
        "description": "Conversations"
      },
      "mailbox": {
        "description": "Mailboxes"
      },
      "customer": {
        "description": "Customers"
      },
      "user": {
        "description": "Team members"
      },
      "tag": {
        "description": "Tags"
      },
      "profile": {
        "description": "Profile management"
      },
      "config": {
        "description": "Configuration"
      },
      "alias": {
        "description": "Command aliases"
      }
    },
    "hooks": {
      "init": "./src/hooks/init",
      "prerun": "./src/hooks/prerun",
      "command_not_found": "./src/hooks/command-not-found"
    },
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins",
      "@oclif/plugin-autocomplete"
    ]
  },
  "dependencies": {
    "@inquirer/prompts": "7.10.1",
    "@napi-rs/keyring": "1.3.0",
    "@oclif/core": "4.11.4",
    "@oclif/plugin-autocomplete": "3.2.50",
    "@oclif/plugin-help": "6.2.49",
    "@oclif/plugin-plugins": "5.4.69",
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "conf": "13.1.0",
    "debug": "4.4.3",
    "js-yaml": "4.1.1",
    "node-jq": "6.3.1",
    "open": "11.0.0",
    "ora": "9.4.0",
    "tar": "7.5.15",
    "undici": "7.26.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@oclif/test": "4.1.18",
    "@vitest/coverage-v8": "4.1.7",
    "eslint": "9.39.4",
    "globals": "17.6.0",
    "nock": "14.0.15",
    "oclif": "4.23.8",
    "prettier": "3.8.3",
    "vitest": "4.1.7"
  },
  "scripts": {
    "build": "oclif manifest",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "npm run build",
    "postpack": "rm -f oclif.manifest.json"
  }
}
