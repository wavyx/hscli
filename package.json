{
  "name": "@wavyx/hscli",
  "version": "0.11.2",
  "publishConfig": {
    "access": "public"
  },
  "description": "Command-line interface for Help Scout",
  "type": "module",
  "license": "MIT",
  "author": "Eric Rodriguez",
  "homepage": "https://github.com/wavyx/hscli",
  "repository": {
    "type": "git",
    "url": "https://github.com/wavyx/hscli.git"
  },
  "bugs": {
    "url": "https://github.com/wavyx/hscli/issues"
  },
  "bin": {
    "hscli": "./bin/run.js"
  },
  "files": [
    "bin",
    "src",
    "oclif.manifest.json",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "helpscout",
    "help-scout",
    "cli",
    "oclif",
    "support",
    "customer-support",
    "inbox"
  ],
  "oclif": {
    "bin": "hscli",
    "dirname": "hscli",
    "commands": {
      "strategy": "pattern",
      "target": "./src/commands",
      "globPatterns": [
        "**/*.js",
        "!**/*.test.js"
      ]
    },
    "topicSeparator": " ",
    "topics": {
      "auth": {
        "description": "Authentication and OAuth management"
      },
      "conv": {
        "description": "Conversations"
      },
      "mailbox": {
        "description": "Mailboxes"
      },
      "customer": {
        "description": "Customers"
      },
      "user": {
        "description": "Team members"
      },
      "tag": {
        "description": "Tags"
      },
      "profile": {
        "description": "Profile management"
      },
      "config": {
        "description": "Configuration"
      },
      "alias": {
        "description": "Command aliases"
      },
      "beacon": {
        "description": "Beacon widget utilities (HMAC signing, snippet generators)"
      },
      "docs": {
        "description": "Help Scout Docs — knowledge base sites, collections, categories, articles"
      },
      "docs:collection": {
        "description": "Docs collections"
      },
      "docs:category": {
        "description": "Docs categories"
      },
      "docs:article": {
        "description": "Docs articles"
      },
      "docs:site": {
        "description": "Docs sites"
      },
      "mcp": {
        "description": "Run hscli as an MCP server for AI agents"
      }
    },
    "hooks": {
      "init": "./src/hooks/init",
      "prerun": "./src/hooks/prerun",
      "command_not_found": "./src/hooks/command-not-found"
    },
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins",
      "@oclif/plugin-autocomplete"
    ]
  },
  "dependencies": {
    "@inquirer/prompts": "8.5.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@napi-rs/keyring": "1.3.0",
    "@oclif/core": "4.11.14",
    "@oclif/plugin-autocomplete": "3.2.53",
    "@oclif/plugin-help": "6.2.53",
    "@oclif/plugin-plugins": "5.4.84",
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "conf": "15.1.0",
    "debug": "4.4.3",
    "js-yaml": "5.2.1",
    "node-jq": "6.3.1",
    "open": "11.0.0",
    "ora": "9.4.1",
    "tar": "7.5.20",
    "undici": "8.8.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@oclif/test": "4.1.20",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "nock": "14.0.16",
    "oclif": "4.23.28",
    "prettier": "3.9.6",
    "vitest": "4.1.10"
  },
  "scripts": {
    "build": "oclif manifest",
    "docs:commands": "node scripts/gen-commands.mjs",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "npm run build",
    "postpack": "rm -f oclif.manifest.json"
  }
}
