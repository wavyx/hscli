# hscli environment variables
# Copy to .env and fill in values: cp .env.example .env

# Auth - bring your own OAuth app (overrides embedded defaults)
HSCLI_APP_ID=
HSCLI_APP_SECRET=
HSCLI_AUTH_MODE=           # set to "client_credentials" for CI/CD

# Runtime
HSCLI_PROFILE=             # override active profile
NO_COLOR=                  # set to "1" to disable color output
DEBUG=                     # set to "hs:*" for all debug logs, or "hs:auth", "hs:client", "hs:keychain"
